# Production activation overlay.
# Start from a fully accepted and already-running controlled deployment. Copy the
# reviewed values below into the controlled host environment only after the real
# end-to-end evidence URLs exist. Never use placeholders and never commit secrets.
#
# Use with:
#   docker compose \
#     --env-file deploy/.env.controlled \
#     --env-file deploy/.env.production-activation \
#     -f deploy/docker-compose.controlled.yml \
#     -f deploy/docker-compose.production-activation.yml \
#     up -d

PRODUCTION_PROFILE=full

# Bind every activation evidence reference to the exact accepted candidate.
# These values must equal GIT_SHA and the digest suffix of CONTROLLED_IMAGE from
# deploy/.env.controlled. The activation preflight rejects any mismatch.
ACTIVATION_EVIDENCE_SOURCE_SHA=<same-40-hex-value-as-GIT_SHA>
ACTIVATION_EVIDENCE_IMAGE_DIGEST=sha256:<same-64-hex-digest-as-CONTROLLED_IMAGE>

# Immutable HTTPS evidence. Each URL must resolve to the actual accepted runbook,
# test report or signed evidence bundle for the bound source SHA and image digest.
PRODUCTION_E2E_EVIDENCE_URL=https://github.com/Maximvonshaft/nexus_helpdesk/actions/runs/<full-production-e2e-run-id>
PROVIDER_CANARY_E2E_EVIDENCE_URL=https://github.com/Maximvonshaft/nexus_helpdesk/actions/runs/<provider-canary-e2e-run-id>
WEBCHAT_AI_PRODUCTION_E2E_EVIDENCE_URL=https://github.com/Maximvonshaft/nexus_helpdesk/actions/runs/<webchat-ai-e2e-run-id>
TELEPHONY_PRODUCTION_E2E_EVIDENCE_URL=
OUTBOUND_PRODUCTION_E2E_EVIDENCE_URL=
OPERATIONS_PRODUCTION_E2E_EVIDENCE_URL=

# Canonical Agent Runtime production activation.
PROVIDER_RUNTIME_ENABLED=true
PROVIDER_RUNTIME_TRAFFIC_MODE=full
PROVIDER_RUNTIME_KILL_SWITCH=false
PROVIDER_RUNTIME_CANARY_PERCENT=100
PRIVATE_AI_RUNTIME_ENABLED=true
WEBCHAT_AI_ENABLED=true
WEBCHAT_AI_AUTO_REPLY_MODE=runtime
WEBCHAT_AI_RECONCILER_ENABLED=true

# Keep optional external capabilities disabled unless their own evidence URL and
# real credentials are present. Enabling a capability without evidence makes the
# full readiness profile fail closed.
WEBCHAT_HUMAN_CALL_ENABLED=false
WEBCHAT_LIVE_AI_VOICE_ENABLED=false
WEBCHAT_VOICE_PROVIDER=mock
LIVEKIT_WEBHOOK_ENABLED=false
ENABLE_OUTBOUND_DISPATCH=false
OUTBOUND_PROVIDER=disabled
OUTBOUND_EMAIL_PRODUCTION_PILOT_ENABLED=false
WHATSAPP_NATIVE_ENABLED=false
WHATSAPP_DISPATCH_MODE=disabled
EMAIL_MAILBOX_SYNC_ENABLED=false
OPERATIONS_DISPATCH_MODE=disabled
OPERATIONS_DISPATCH_ADAPTER=disabled
