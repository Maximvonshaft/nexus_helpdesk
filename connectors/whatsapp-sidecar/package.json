{
  "name": "@nexusdesk/whatsapp-sidecar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "NexusDesk native WhatsApp Web sidecar connector",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
