NEXUSDESK_SERVER_NAMES=leakle.com www.leakle.com 178.105.160.174 _
NEXUSDESK_APP_UPSTREAM=http://127.0.0.1:18081
NEXUSDESK_CLIENT_MAX_BODY_SIZE=50m
NEXUSDESK_PROXY_READ_TIMEOUT=90s
NEXUSDESK_PROXY_SEND_TIMEOUT=90s
NEXUSDESK_PROXY_CONNECT_TIMEOUT=10s

# Prefer an internal MCS/voice gateway that owns the AI Runtime token. If direct
# upstream binding is temporarily required, render any token-bearing URL from a
# root-owned runtime env file outside the repository.
LIVE_VOICE_WS_READ_TIMEOUT=3600s
LIVE_VOICE_WS_SEND_TIMEOUT=3600s

DSP_RESEARCH_STATIC_ROOT=/opt/speedaf_dsp/research
DSP_APP_UPSTREAM=http://127.0.0.1:8021
