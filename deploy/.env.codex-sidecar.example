# Optional Codex sidecar override.
# This is experimental and is not required for the default production path.

CODEX_SIDECAR_INTEGRATION_ENABLED=true
PROVIDER_RUNTIME_PRIMARY_PROVIDER=codex_app_server
PROVIDER_RUNTIME_FALLBACK_PROVIDERS=[]
CODEX_DIRECT_ENABLED=false

CODEX_APP_SERVER_PROVIDER_ENABLED=true
WEBCHAT_FAST_AI_CODEX_APP_SERVER_ENABLED=true
CODEX_APP_SERVER_BRIDGE_URL=http://codex-app-server-bridge:18794/reply
CODEX_APP_SERVER_LOGIN_URL=http://codex-app-server-bridge:18794/login
CODEX_APP_SERVER_TOKEN_FILE=/run/nexus/codex_app_server_bridge_token
CODEX_APP_SERVER_BRIDGE_MODE=real
CODEX_APP_SERVER_REAL_UPSTREAM_URL=http://codex-app-server-upstream:18795/reply
CODEX_APP_SERVER_REPLY_GENERATION_BACKEND=codex_app_server
CODEX_APP_SERVER_CANARY_PERCENT=100
CODEX_APP_SERVER_KILL_SWITCH=false
