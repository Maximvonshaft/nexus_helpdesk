# RETIRED COMPATIBILITY PATH — DO NOT COPY AS A RUNTIME ENVIRONMENT.
#
# Use deploy/.env.controlled.example with:
#   NEXUS_DATABASE_TOPOLOGY=external deploy/nexus-prod-compose.sh ...
#
# The canonical template uses six distinct PostgreSQL service identities and
# does not inject one shared environment into every container.

NEXUS_ENV_TEMPLATE_RETIRED=true
NEXUS_DATABASE_TOPOLOGY=external
NEXUS_CANONICAL_ENV_TEMPLATE=deploy/.env.controlled.example
