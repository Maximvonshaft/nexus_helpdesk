# RETIRED COMPATIBILITY PATH — DO NOT COPY AS A RUNTIME ENVIRONMENT.
#
# Use deploy/.env.controlled.local-postgres.example with:
#   NEXUS_DATABASE_TOPOLOGY=local deploy/nexus-prod-compose.sh ...
#
# Existing production-local deploy/.env.prod and docker-compose.server.yml files
# must be backed up and preserved; this repository tombstone does not authorize
# overwriting the live host.

NEXUS_ENV_TEMPLATE_RETIRED=true
NEXUS_DATABASE_TOPOLOGY=local
NEXUS_CANONICAL_ENV_TEMPLATE=deploy/.env.controlled.local-postgres.example
