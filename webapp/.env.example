# Same-origin production deploy: leave empty.
VITE_API_BASE_URL=

# Contract: provide only the origin/base host. Do not include /api.
# The webapp API client already calls /api/... paths and defensively normalizes
# an accidental trailing /api to prevent /api/api requests.
#
# Local webapp talking to a deployed/cloud backend examples:
# VITE_API_BASE_URL=https://your-domain.com
# VITE_API_BASE_URL=http://backend-host:18081
#
# Incorrect:
# VITE_API_BASE_URL=http://backend-host:18081/api
