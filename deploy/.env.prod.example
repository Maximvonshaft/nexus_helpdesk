# NexusDesk production environment template. Do not commit real values.
# Copy to deploy/.env.prod on the server and fill real values there.

APP_ENV=production
SECRET_KEY=replace-with-a-long-random-value
JWT_ISSUER=nexusdesk
JWT_AUDIENCE=nexusdesk-users
ACCESS_TOKEN_EXPIRE_HOURS=12

# Runtime build identity. Deployment scripts should export these before build/up.
GIT_SHA=unknown
BUILD_TIME=unknown
IMAGE_TAG=nexusdesk/helpdesk:server
APP_VERSION=server
FRONTEND_BUILD_SHA=unknown

# Database. Default server compose uses the internal postgres service.
POSTGRES_DB=nexusdesk
POSTGRES_USER=nexusdesk
POSTGRES_PASSWORD=replace-with-strong-postgres-password
DATABASE_URL=postgresql+psycopg://nexusdesk:replace-with-strong-postgres-password@postgres:5432/nexusdesk
DATABASE_ECHO=false
AUTO_INIT_DB=false
SEED_DEMO_DATA=false
ALLOW_DEV_AUTH=false
ALLOW_LEGACY_INTEGRATION_API_KEY=false

# Reverse proxy / CORS.
# Standard controlled-pilot API entrypoint is host 127.0.0.1:18081 -> app container 8080.
# Edge nginx remains optional behind the edge-nginx compose profile.
APP_HOST_PORT=18081
ALLOWED_ORIGINS=https://your-helpdesk-domain.example
TRUSTED_PROXY_IPS=127.0.0.1

# Storage.
# Strict production recommendation: s3.
# Controlled pilot fallback: STORAGE_BACKEND=local with ../data/uploads mounted to /app/backend/uploads and backed up daily.
STORAGE_BACKEND=s3
UPLOAD_ROOT=/app/backend/uploads
S3_BUCKET=replace-with-bucket
S3_REGION=auto
S3_ENDPOINT_URL=https://s3.example.com
S3_ACCESS_KEY=replace-with-access-key
S3_SECRET_KEY=replace-with-secret-key
S3_PRESIGN_EXPIRY_SECONDS=900

# Legacy OpenClaw compatibility. Keep disabled; runtime bridge/MCP/CLI are retired.
OPENCLAW_DEPLOYMENT_MODE=disabled
OPENCLAW_TRANSPORT=disabled
OPENCLAW_MCP_COMMAND=
OPENCLAW_EXTRA_PATHS=
OPENCLAW_MCP_URL=
OPENCLAW_MCP_TOKEN_FILE=
OPENCLAW_MCP_PASSWORD_FILE=
OPENCLAW_CLI_FALLBACK_ENABLED=false
OPENCLAW_BRIDGE_ENABLED=false
OPENCLAW_BRIDGE_URL=
OPENCLAW_BRIDGE_AI_REPLY_ENABLED=false
OPENCLAW_BRIDGE_ALLOW_WRITES=false
OPENCLAW_SYNC_ENABLED=false
OPENCLAW_INBOUND_AUTO_SYNC_ENABLED=false
OPENCLAW_INBOUND_SYNC_LIMIT=10
OPENCLAW_INBOUND_SYNC_MESSAGE_LIMIT=20
OPENCLAW_INBOUND_SYNC_INCLUDE_GROUPS=false
OPENCLAW_EVENT_DRIVER_ENABLED=false
ENABLE_OUTBOUND_DISPATCH=false
OUTBOUND_PROVIDER=disabled
OUTBOUND_EMAIL_ENCRYPTION_KEY_FILE=/run/nexus/outbound_email_encryption_key
# Keep false until an admin has configured SMTP, run a successful test-send,
# and the rollout owner accepts real Email dispatch pilot risk.
OUTBOUND_EMAIL_PRODUCTION_PILOT_ENABLED=false
OUTBOUND_EMAIL_TEST_SEND_MAX_AGE_HOURS=24

# Queues / workers.
OUTBOX_BATCH_SIZE=50
OUTBOX_LOCK_SECONDS=300
OUTBOX_MAX_RETRIES=3
JOB_BATCH_SIZE=25
JOB_LOCK_SECONDS=300
JOB_MAX_RETRIES=3
WORKER_POLL_SECONDS=2

# Webchat.
WEBCHAT_ALLOWED_ORIGINS=https://your-customer-site.example
WEBCHAT_ALLOW_NO_ORIGIN=false
WEBCHAT_ALLOW_LEGACY_TOKEN_TRANSPORT=false
WEBCHAT_RATE_LIMIT_BACKEND=database
WEBCHAT_RATE_LIMIT_WINDOW_SECONDS=60
WEBCHAT_RATE_LIMIT_MAX_REQUESTS=20
WEBCHAT_AI_AUTO_REPLY_MODE=safe_ack

# Metrics / observability.
LOG_JSON=true
METRICS_ENABLED=false
METRICS_TOKEN=
REQUIRE_PROMETHEUS_CLIENT_IN_PRODUCTION=true

# Legacy inbound attachment compatibility.
OPENCLAW_ATTACHMENT_URL_FETCH_ENABLED=false
OPENCLAW_ATTACHMENT_ALLOWED_HOSTS=
OPENCLAW_ATTACHMENT_FETCH_TIMEOUT_SECONDS=10
OPENCLAW_ATTACHMENT_MAX_DOWNLOAD_BYTES=10485760

# Webchat Fast Settings
WEBCHAT_FAST_AI_ENABLED=true
WEBCHAT_FAST_STREAM_ENABLED=false
WEBCHAT_FAST_STREAM_ROLLOUT_PERCENT=0

# Provider Runtime
PROVIDER_RUNTIME_ENABLED=true
PROVIDER_CREDENTIAL_ENCRYPTION_KEY_FILE=/run/nexus/provider_credential_key
# DO NOT USE PLAIN TEXT ENCRYPTION KEY IN PRODUCTION
# PROVIDER_CREDENTIAL_ENCRYPTION_KEY=

CODEX_OAUTH_DEVICE_FLOW_ENABLED=false
CODEX_APP_SERVER_PROVIDER_ENABLED=false
CODEX_APP_SERVER_BRIDGE_URL=http://172.18.0.1:18794/reply
CODEX_APP_SERVER_LOGIN_URL=http://172.18.0.1:18794/login
CODEX_APP_SERVER_TOKEN_FILE=/run/nexus/codex_app_server_bridge_token
CODEX_APP_SERVER_BRIDGE_MODE=real
CODEX_APP_SERVER_REAL_UPSTREAM_URL=http://127.0.0.1:18795/reply
CODEX_APP_SERVER_REPLY_GENERATION_BACKEND=codex_app_server
CODEX_APP_SERVER_CANARY_PERCENT=1
CODEX_APP_SERVER_KILL_SWITCH=false

WEBCHAT_FAST_AI_PROVIDER=provider_runtime
WEBCHAT_FAST_AI_FALLBACK_PROVIDER=rule_engine

# Hardened Codex Direct. Disabled by default; enable only after the Codex CLI
# runs in an isolated runtime with no repository checkout, no app secrets in env,
# a dedicated HOME/CODEX_HOME, and no unintended filesystem/tool access.
PROVIDER_RUNTIME_PRIMARY_PROVIDER=codex_app_server
PROVIDER_RUNTIME_FALLBACK_PROVIDERS=openai_responses,rule_engine
PROVIDER_RUNTIME_OUTPUT_CONTRACT=speedaf_webchat_fast_reply_v1
PROVIDER_RUNTIME_TIMEOUT_MS=10000
PROVIDER_RUNTIME_CANARY_PERCENT=100
PROVIDER_RUNTIME_KILL_SWITCH=false
CODEX_DIRECT_ENABLED=false
CODEX_DIRECT_COMMAND=/usr/local/bin/codex
CODEX_DIRECT_HOME=/app
CODEX_DIRECT_MODEL=gpt-5.3-codex-spark
CODEX_DIRECT_TIMEOUT_SECONDS=25
CODEX_DIRECT_MAX_PROMPT_CHARS=12000
CODEX_DIRECT_REQUIRE_JSON=true
CODEX_DIRECT_EXEC_ARGS_TEMPLATE=exec --model {model} --skip-git-repo-check -
CODEX_DIRECT_SANDBOX_ACKNOWLEDGED=false
CODEX_DIRECT_ALLOW_NETWORK_ENV=false
CODEX_DIRECT_FALLBACK_ALLOWED=true

# Codex / Code X OAuth credential broker
CODEX_OAUTH_AUTHORIZATION_CODE_ENABLED=false
CODEX_OAUTH_AUTHORIZATION_URL=https://codex-auth.example/authorize
CODEX_OAUTH_REDIRECT_URI=https://your-helpdesk-domain.example/api/admin/provider-credentials/codex/callback
CODEX_OAUTH_REVOKE_URL=https://codex-auth.example/oauth/revoke
CODEX_OAUTH_ALLOWED_SCOPES=
CODEX_OAUTH_DEFAULT_SCOPES=
CODEX_OAUTH_CLIENT_SECRET_FILE=/run/nexus/codex_oauth_client_secret
CODEX_OAUTH_STATE_TTL_SECONDS=600
CODEX_OAUTH_INCLUDE_NONCE=true
CODEX_OAUTH_CALLBACK_SUCCESS_REDIRECT_URL=https://your-helpdesk-domain.example/provider-credentials
CODEX_OAUTH_CALLBACK_FAILURE_REDIRECT_URL=https://your-helpdesk-domain.example/provider-credentials
PROVIDER_RUNTIME_DEFAULT_TENANT_ID=default

WEBCHAT_FAST_AI_CODEX_APP_SERVER_ENABLED=false
