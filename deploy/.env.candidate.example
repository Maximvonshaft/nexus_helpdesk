# Copy to deploy/.env.candidate on the server and fill from the release job.
# Do not commit deploy/.env.candidate.

IMAGE_TAG=nexusdesk/helpdesk:main-<git-sha>-<build-time>
GIT_SHA=<git-sha>
BUILD_TIME=<yyyyMMddTHHmmssZ>
APP_VERSION=main-<git-sha-short>
FRONTEND_BUILD_SHA=<git-sha>
CANDIDATE_APP_PORT=18082
CANDIDATE_EXTERNAL_NETWORK=deploy_default
CANDIDATE_WA_SIDECAR_PORT=18795
CANDIDATE_WHATSAPP_SESSION_ROOT=/opt/nexus_helpdesk/data/whatsapp-sessions-candidate
CANDIDATE_NEXUS_BACKEND_URL=http://app-candidate:8080

DATABASE_URL=<candidate-or-readonly-database-url>
APP_ENV=production
AUTO_INIT_DB=false
SEED_DEMO_DATA=false
WEB_CONCURRENCY=2
WEB_TIMEOUT=30

# Native WhatsApp candidate path. Values must come from server secret storage.
WHATSAPP_NATIVE_ENABLED=true
WHATSAPP_DISPATCH_MODE=native_sidecar
WHATSAPP_SIDECAR_URL=http://whatsapp-sidecar-candidate:18793
WHATSAPP_SIDECAR_TOKEN=<sidecar-internal-token>
WHATSAPP_CONNECTOR_KEY=<connector-key>
WHATSAPP_CONNECTOR_HMAC_SECRET=<connector-hmac-secret>
WA_SIDECAR_INTERNAL_TOKEN=<sidecar-internal-token>
NEXUS_CONNECTOR_KEY=<connector-key>
NEXUS_CONNECTOR_HMAC_SECRET=<connector-hmac-secret>
WA_SIDECAR_CONNECTOR_MODE=baileys
WA_SIDECAR_AUTO_START_ACCOUNTS=wa-main
WA_SIDECAR_ALLOW_FROM_ME_INBOUND=false
WA_SIDECAR_FROM_ME_MODE=ignore
WA_SIDECAR_FROM_ME_TEST_PREFIX=NEXUS_SELF_INBOUND_TEST
WA_SIDECAR_BROWSER_PLATFORM=Ubuntu
WA_SIDECAR_BROWSER_NAME=NexusDesk
WA_SIDECAR_BROWSER_VERSION=22.04.4
WA_SIDECAR_KEEPALIVE_INTERVAL_MS=25000
WA_SIDECAR_CONNECT_TIMEOUT_MS=60000
WA_SIDECAR_DEFAULT_QUERY_TIMEOUT_MS=60000
WA_SIDECAR_OPERATION_TIMEOUT_MS=60000
WA_SIDECAR_QR_TTL_MS=120000
WA_SIDECAR_RECONNECT_BASE_DELAY_MS=2000
WA_SIDECAR_RECONNECT_MAX_DELAY_MS=30000
WA_SIDECAR_RECONNECT_MAX_ATTEMPTS=20

# Speedaf read-only AI lookup can be enabled after GitHub/UAT smoke passes.
WEBCHAT_TRACKING_FACT_SOURCE=speedaf_api
SPEEDAF_MCP_ENABLED=false
SPEEDAF_WORK_ORDER_CREATE_ENABLED=false
SPEEDAF_UPDATE_ADDRESS_ENABLED=false
SPEEDAF_CANCEL_ENABLED=false
SPEEDAF_VOICE_CALLBACK_ENABLED=false
