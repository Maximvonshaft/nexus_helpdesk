# Nexus controlled candidate input.
# Copy to .env.controlled on the controlled host and invoke Compose with:
#   docker compose --env-file .env.controlled -f deploy/docker-compose.controlled.yml ...
# Add `--profile telephony` only after all real LiveKit/SIP/STT/TTS prerequisites
# below are populated and the controlled call matrix is ready to run.
# Compose uses this file only for variable substitution. It is not injected into
# every container as an env_file. Never commit real credentials.

# Immutable candidate identity. Real values come from the accepted manifest.
COMPOSE_PROJECT_NAME=nexusdesk_controlled
CONTROLLED_IMAGE=ghcr.io/maximvonshaft/nexus_helpdesk@sha256:<64-hex-digest>
IMAGE_TAG=ghcr.io/maximvonshaft/nexus_helpdesk@sha256:<64-hex-digest>
GIT_SHA=<40-hex-source-sha>
FRONTEND_BUILD_SHA=<40-hex-source-sha>
EXPECTED_MIGRATION_HEAD=20260722_tel5
BUILD_TIME=<manifest-build-time>
APP_VERSION=<manifest-app-version>
READINESS_REQUIRE_RELEASE_METADATA=true
CONTROLLED_APP_PORT=18095

# Host data paths.
NEXUS_UPLOADS_HOST_PATH=/opt/nexus_helpdesk/data/uploads
NEXUS_UPLOAD_BACKUP_HOST_PATH=/var/backups/nexusdesk/uploads

# Each process has a distinct PostgreSQL login. The migration identity is the
# only role that may hold schema-change privileges.
DATABASE_URL_MIGRATION=postgresql+psycopg://nexus_migration:<migration-password>@10.2.64.2:5432/nexusdesk
DATABASE_URL_APP=postgresql+psycopg://nexus_app:<app-password>@10.2.64.2:5432/nexusdesk
DATABASE_URL_OUTBOUND=postgresql+psycopg://nexus_outbound:<outbound-password>@10.2.64.2:5432/nexusdesk
DATABASE_URL_BACKGROUND=postgresql+psycopg://nexus_background:<background-password>@10.2.64.2:5432/nexusdesk
DATABASE_URL_WEBCHAT_AI=postgresql+psycopg://nexus_webchat_ai:<webchat-ai-password>@10.2.64.2:5432/nexusdesk
DATABASE_URL_HANDOFF=postgresql+psycopg://nexus_handoff:<handoff-password>@10.2.64.2:5432/nexusdesk
DATABASE_ECHO=false

# Web-process secrets and browser boundary.
SECRET_KEY=<web-jwt-secret-at-least-32-characters>
RUNTIME_CONTRACT_SIGNING_SECRET=<runtime-contract-signing-secret-at-least-32-characters>
METRICS_TOKEN=<dedicated-metrics-token-at-least-32-characters>
ALLOWED_ORIGINS=https://mcs.speedaf.com
WEBCHAT_ALLOWED_ORIGINS=https://mcs.speedaf.com
TRUSTED_PROXY_IPS=127.0.0.1

# Per-process PostgreSQL connection budgets.
DB_POOL_SIZE_WEB=5
DB_MAX_OVERFLOW_WEB=5
DB_POOL_SIZE_OUTBOUND=2
DB_MAX_OVERFLOW_OUTBOUND=2
DB_POOL_SIZE_BACKGROUND=3
DB_MAX_OVERFLOW_BACKGROUND=2
DB_POOL_SIZE_WEBCHAT_AI=2
DB_MAX_OVERFLOW_WEBCHAT_AI=1
DB_POOL_SIZE_HANDOFF=2
DB_MAX_OVERFLOW_HANDOFF=1
DB_POOL_SIZE_MIGRATION=1
DB_MAX_OVERFLOW_MIGRATION=0
DB_POOL_TIMEOUT_SECONDS=10
DB_POOL_RECYCLE_SECONDS=1800
QUEUE_METRICS_SNAPSHOT_INTERVAL_SECONDS=15
BUSINESS_QUEUE_MAX_READY_AGE_SECONDS=300

# Local storage is accepted only with a fresh content-equality marker generated
# by scripts/qualification/local_storage_backup.py after the backup copy finishes.
STORAGE_BACKEND=local
UPLOAD_ROOT=/app/backend/uploads
LOCAL_STORAGE_BACKUP_REQUIRED=true
LOCAL_STORAGE_BACKUP_PATH=/var/backups/nexusdesk/uploads
LOCAL_STORAGE_BACKUP_MARKER_PATH=/var/backups/nexusdesk/uploads/.nexus-backup-verified.json
LOCAL_STORAGE_BACKUP_MAX_AGE_SECONDS=86400
LOCAL_STORAGE_BACKUP_ENFORCE_FRESHNESS=true
LOCAL_STORAGE_BACKUP_ACKNOWLEDGED=true
REQUIRE_REMOTE_STORAGE_IN_PRODUCTION=false

APP_ENV=production
TENANT_RUNTIME_AUTHORITY_MODE=enforce
AUTO_INIT_DB=false
SEED_DEMO_DATA=false
ALLOW_DEV_AUTH=false
ALLOW_LEGACY_INTEGRATION_API_KEY=false
WEBCHAT_ALLOW_NO_ORIGIN=false
WEBCHAT_ALLOW_LEGACY_TOKEN_TRANSPORT=false
WEBCHAT_AI_ENABLED=false
WEBCHAT_AI_AUTO_REPLY_MODE=off
WEBCHAT_AI_RECONCILER_ENABLED=false
WEBCHAT_WS_ENABLED=false
WEBCHAT_WS_PUBLIC_ENABLED=false
WEBCHAT_WS_ADMIN_ENABLED=false
WEBCHAT_WS_BROKER=database

# Canonical LiveKit media plane. Keep all values fail-closed until the actual
# LiveKit project, carrier, DID, trunks, dispatch rule and webhook are ready.
WEBCHAT_HUMAN_CALL_ENABLED=false
WEBCHAT_LIVE_AI_VOICE_ENABLED=false
WEBCHAT_VOICE_PROVIDER=mock
WEBCHAT_VOICE_ROUTING_MODE=human_first
WEBCHAT_VOICE_ALLOWED_PATH_PREFIXES=/webchat,/webcall,/api/webchat,/api/telephony
WEBCHAT_VOICE_CONNECT_SRC=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_API_KEY_FILE=
LIVEKIT_API_SECRET_FILE=
LIVEKIT_AGENT_NAME=nexus-voice-agent
LIVEKIT_AGENT_SHARED_SECRET=
LIVEKIT_AGENT_SHARED_SECRET_FILE=
LIVEKIT_WEBHOOK_ENABLED=false

# Canonical LiveKit Agent media worker. It performs STT/TTS and room control;
# all business reasoning and Tools remain in the Nexus Agent Runtime.
NEXUS_VOICE_STT_MODEL=
NEXUS_VOICE_TTS_MODEL=
# Optional. Used only by LiveKit's bounded WarmTransferTask consultation.
NEXUS_VOICE_TRANSFER_LLM_MODEL=
NEXUS_VOICE_TURN_DETECTION=stt
NEXUS_VOICE_AGENT_REQUEST_TIMEOUT_SECONDS=30
NEXUS_VOICE_AGENT_HEARTBEAT_SECONDS=30
NEXUS_VOICE_GREETING=Hello. How can I help you today?
NEXUS_VOICE_HANDOFF_WAIT_MESSAGE=Your request is waiting for a human support agent. Please stay on the line.

PROVIDER_RUNTIME_ENABLED=false
PROVIDER_RUNTIME_TRAFFIC_MODE=control
PROVIDER_RUNTIME_KILL_SWITCH=true
PROVIDER_RUNTIME_CANARY_PERCENT=0
PRIVATE_AI_RUNTIME_ENABLED=false
KNOWLEDGE_EMBEDDINGS_ENABLED=false
ENABLE_OUTBOUND_DISPATCH=false
OUTBOUND_PROVIDER=disabled
OUTBOUND_EMAIL_PRODUCTION_PILOT_ENABLED=false
WHATSAPP_NATIVE_ENABLED=false
WHATSAPP_DISPATCH_MODE=disabled
EMAIL_MAILBOX_SYNC_ENABLED=false
ALLOW_LEGACY_ORIGINLESS_OUTBOUND=false
WEBCHAT_TRACKING_FACT_LOOKUP_ENABLED=false
SPEEDAF_MCP_ENABLED=false
SPEEDAF_TRACK_QUERY_ENABLED=false
SPEEDAF_WORK_ORDER_CREATE_ENABLED=false
SPEEDAF_UPDATE_ADDRESS_ENABLED=false
SPEEDAF_CANCEL_ENABLED=false
SPEEDAF_VOICE_CALLBACK_ENABLED=false
OPERATIONS_DISPATCH_MODE=disabled
OPERATIONS_DISPATCH_ADAPTER=disabled
