APP_ENV=development
DATABASE_URL=sqlite:///./helpdesk.db
# Production example:
# DATABASE_URL=postgresql+psycopg://helpdesk:password@localhost:5432/helpdesk
SECRET_KEY=change-me
RUNTIME_CONTRACT_SIGNING_SECRET=
JWT_ISSUER=helpdesk-suite
JWT_AUDIENCE=helpdesk-suite-users
ACCESS_TOKEN_EXPIRE_HOURS=12
AUTO_INIT_DB=false
SEED_DEMO_DATA=false
ALLOW_DEV_AUTH=false

STORAGE_BACKEND=local
UPLOAD_ROOT=./uploads
MAX_UPLOAD_BYTES=10485760
ALLOWED_UPLOAD_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf,text/plain,text/markdown,text/csv,text/html,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet
ALLOWED_UPLOAD_EXTENSIONS=.jpg,.jpeg,.png,.webp,.pdf,.txt,.md,.markdown,.csv,.html,.htm,.docx,.xlsx

ENABLE_OUTBOUND_DISPATCH=false
OUTBOUND_PROVIDER=disabled
WHATSAPP_DISPATCH_MODE=disabled
WHATSAPP_NATIVE_ENABLED=false
WHATSAPP_SIDECAR_URL=http://127.0.0.1:18793
WHATSAPP_SIDECAR_TOKEN=
WHATSAPP_SIDECAR_TIMEOUT_SECONDS=8
WHATSAPP_CONNECTOR_KEY=
WHATSAPP_CONNECTOR_HMAC_SECRET=
WHATSAPP_CONNECTOR_TIMESTAMP_TOLERANCE_SECONDS=300
OUTBOUND_EMAIL_PRODUCTION_PILOT_ENABLED=false
OUTBOUND_EMAIL_TEST_SEND_MAX_AGE_HOURS=24
OUTBOX_BATCH_SIZE=50
OUTBOX_LOCK_SECONDS=300
OUTBOX_MAX_RETRIES=3
JOB_BATCH_SIZE=25
JOB_LOCK_SECONDS=300
JOB_MAX_RETRIES=3
WORKER_POLL_SECONDS=2

ALLOW_LEGACY_INTEGRATION_API_KEY=false
INTEGRATION_API_KEY=
INTEGRATION_DEFAULT_RATE_LIMIT_PER_MINUTE=60
INTEGRATION_REQUIRE_IDEMPOTENCY_KEY=true

LOGIN_MAX_FAILURES=5
LOGIN_LOCK_MINUTES=15
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
WEBCHAT_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
WEBCHAT_ALLOW_NO_ORIGIN=false
WEBCHAT_ALLOW_LEGACY_TOKEN_TRANSPORT=false
WEBCHAT_RATE_LIMIT_BACKEND=memory

S3_BUCKET=
S3_ENDPOINT_URL=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PRESIGN_EXPIRY_SECONDS=900
LOG_JSON=true
METRICS_ENABLED=false
METRICS_TOKEN=replace-with-strong-metrics-token
REQUIRE_PROMETHEUS_CLIENT_IN_PRODUCTION=true
REQUEST_ID_HEADER=X-Request-Id
TRUSTED_PROXY_IPS=127.0.0.1/32,::1/128

# Canonical LiveKit media plane. Production should provide secrets through
# *_FILE variables or an approved deployment secret injector.
WEBCHAT_HUMAN_CALL_ENABLED=false
WEBCHAT_LIVE_AI_VOICE_ENABLED=false
WEBCHAT_VOICE_PROVIDER=mock
WEBCHAT_VOICE_ROUTING_MODE=human_first
WEBCHAT_VOICE_CONNECT_SRC=
WEBCHAT_VOICE_SESSION_TTL_SECONDS=900
WEBCHAT_VOICE_MAX_ACTIVE_PER_CONVERSATION=1
WEBCHAT_VOICE_RATE_LIMIT_WINDOW_SECONDS=60
WEBCHAT_VOICE_RATE_LIMIT_MAX_REQUESTS=5
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_API_KEY_FILE=
LIVEKIT_API_SECRET_FILE=
LIVEKIT_AGENT_NAME=nexus-voice-agent
LIVEKIT_AGENT_SHARED_SECRET=
LIVEKIT_AGENT_SHARED_SECRET_FILE=
LIVEKIT_WEBHOOK_ENABLED=false

# Canonical LiveKit Agent media worker. This process performs STT/TTS and room
# controls only; every business decision and Tool call goes back to Nexus Agent Runtime.
NEXUS_INTERNAL_API_URL=http://127.0.0.1:8080
NEXUS_VOICE_STT_MODEL=
NEXUS_VOICE_TTS_MODEL=
NEXUS_VOICE_TURN_DETECTION=stt
NEXUS_VOICE_AGENT_REQUEST_TIMEOUT_SECONDS=30
NEXUS_VOICE_AGENT_HEARTBEAT_SECONDS=30
NEXUS_VOICE_GREETING=Hello. How can I help you today?
NEXUS_VOICE_HANDOFF_WAIT_MESSAGE=Your request is waiting for a human support agent. Please stay on the line.

WEBCHAT_KNOWLEDGE_REPLY_MODE=ai_grounded
WEBCHAT_WS_ENABLED=false
WEBCHAT_WS_PUBLIC_ENABLED=false
WEBCHAT_WS_ADMIN_ENABLED=false
WEBCHAT_WS_BROKER=database
WEBCHAT_WS_REPLAY_POLL_MS=500
WEBCHAT_WS_FALLBACK_POLL_MS=4000
WEBCHAT_WS_HEARTBEAT_MS=25000
WEBCHAT_WS_HELLO_TIMEOUT_MS=5000
WEBCHAT_WS_MAX_CONNECTIONS=1000
WEBCHAT_WS_MAX_CONNECTIONS_PER_USER=10

STT_PROVIDER=fake
LLM_PROVIDER=fake
TTS_PROVIDER=fake
STT_ENDPOINT=
STT_API_KEY_FILE=
LLM_ENDPOINT=
LLM_API_KEY_FILE=
TTS_ENDPOINT=
TTS_API_KEY_FILE=
TRACKING_LOOKUP_ENDPOINT=
TRACKING_LOOKUP_API_KEY_FILE=
