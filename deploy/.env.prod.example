# NexusDesk production environment template. Do not commit real values.
# Copy to deploy/.env.prod on the server and fill real values there.

APP_ENV=production
SECRET_KEY=replace-with-a-long-random-value
JWT_ISSUER=nexusdesk
JWT_AUDIENCE=nexusdesk-users
ACCESS_TOKEN_EXPIRE_HOURS=12

# Runtime build identity. Deployment scripts should export these before build/up.
GIT_SHA=unknown
BUILD_TIME=unknown
IMAGE_TAG=nexusdesk/helpdesk:server
APP_VERSION=server
FRONTEND_BUILD_SHA=unknown

# Database. Default server compose uses the internal postgres service.
POSTGRES_DB=nexusdesk
POSTGRES_USER=nexusdesk
POSTGRES_PASSWORD=replace-with-strong-postgres-password
DATABASE_URL=postgresql+psycopg://nexusdesk:replace-with-strong-postgres-password@postgres:5432/nexusdesk
DATABASE_ECHO=false
AUTO_INIT_DB=false
SEED_DEMO_DATA=false
ALLOW_DEV_AUTH=false
ALLOW_LEGACY_INTEGRATION_API_KEY=false

# Reverse proxy / CORS.
# Standard controlled-pilot API entrypoint is host 127.0.0.1:18081 -> app container 8080.
# Edge nginx remains optional behind the edge-nginx compose profile.
APP_HOST_PORT=18081
ALLOWED_ORIGINS=https://your-helpdesk-domain.example
TRUSTED_PROXY_IPS=127.0.0.1

# Storage.
# Strict production recommendation: s3.
# Controlled pilot fallback: STORAGE_BACKEND=local with ../data/uploads mounted to /app/backend/uploads and backed up daily.
STORAGE_BACKEND=s3
UPLOAD_ROOT=/app/backend/uploads
S3_BUCKET=replace-with-bucket
S3_REGION=auto
S3_ENDPOINT_URL=https://s3.example.com
S3_ACCESS_KEY=replace-with-access-key
S3_SECRET_KEY=replace-with-secret-key
S3_PRESIGN_EXPIRY_SECONDS=900

# OpenClaw / bridge.
OPENCLAW_DEPLOYMENT_MODE=remote_gateway
OPENCLAW_TRANSPORT=mcp
OPENCLAW_MCP_COMMAND=openclaw
OPENCLAW_EXTRA_PATHS=
OPENCLAW_MCP_URL=wss://your-openclaw-gateway.example/mcp
OPENCLAW_MCP_TOKEN_FILE=/run/secrets/openclaw_mcp_token
OPENCLAW_MCP_PASSWORD_FILE=
OPENCLAW_CLI_FALLBACK_ENABLED=false
OPENCLAW_BRIDGE_ENABLED=false
OPENCLAW_BRIDGE_URL=http://127.0.0.1:18792
# Bridge safety split:
# - OPENCLAW_BRIDGE_AI_REPLY_ENABLED controls internal WebChat AI reply generation via /ai-reply.
# - OPENCLAW_BRIDGE_ALLOW_WRITES controls external customer-facing /send-message dispatch.
# Keep writes disabled unless outbound dispatch is intentionally enabled and verified.
OPENCLAW_BRIDGE_AI_REPLY_ENABLED=true
OPENCLAW_BRIDGE_ALLOW_WRITES=false
OPENCLAW_SYNC_ENABLED=true
# Set false by default if you want to avoid production auto-ticket creation until manual verification completes.
OPENCLAW_INBOUND_AUTO_SYNC_ENABLED=false
OPENCLAW_INBOUND_SYNC_LIMIT=10
OPENCLAW_INBOUND_SYNC_MESSAGE_LIMIT=20
OPENCLAW_INBOUND_SYNC_INCLUDE_GROUPS=false
OPENCLAW_EVENT_DRIVER_ENABLED=true
ENABLE_OUTBOUND_DISPATCH=false
OUTBOUND_PROVIDER=disabled

# Queues / workers.
OUTBOX_BATCH_SIZE=50
OUTBOX_LOCK_SECONDS=300
OUTBOX_MAX_RETRIES=3
JOB_BATCH_SIZE=25
JOB_LOCK_SECONDS=300
JOB_MAX_RETRIES=3
WORKER_POLL_SECONDS=2
OPENCLAW_SYNC_ENABLED=true

# Webchat.
WEBCHAT_ALLOWED_ORIGINS=https://your-customer-site.example
WEBCHAT_ALLOW_NO_ORIGIN=false
WEBCHAT_ALLOW_LEGACY_TOKEN_TRANSPORT=false
WEBCHAT_RATE_LIMIT_BACKEND=database
WEBCHAT_RATE_LIMIT_WINDOW_SECONDS=60
WEBCHAT_RATE_LIMIT_MAX_REQUESTS=20
WEBCHAT_AI_AUTO_REPLY_MODE=safe_ack

# Metrics / observability.
LOG_JSON=true
METRICS_ENABLED=false
METRICS_TOKEN=
REQUIRE_PROMETHEUS_CLIENT_IN_PRODUCTION=true

# Attachment URL fetch safety.
OPENCLAW_ATTACHMENT_URL_FETCH_ENABLED=false
OPENCLAW_ATTACHMENT_ALLOWED_HOSTS=
OPENCLAW_ATTACHMENT_FETCH_TIMEOUT_SECONDS=10
OPENCLAW_ATTACHMENT_MAX_DOWNLOAD_BYTES=10485760
