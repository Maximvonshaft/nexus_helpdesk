[Unit]
Description=NexusDesk API
After=network.target nexusdesk-openclaw-bridge.service
Wants=nexusdesk-openclaw-bridge.service

[Service]
WorkingDirectory=/opt/nexusdesk/backend
EnvironmentFile=/opt/nexusdesk/backend/.env.production
ExecStartPre=/opt/nexusdesk/venv/bin/python /opt/nexusdesk/backend/scripts/wait_for_openclaw_bridge.py --timeout 20
ExecStart=/opt/nexusdesk/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
