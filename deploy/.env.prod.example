# RETIRED COMPATIBILITY PATH — DO NOT COPY AS A RUNTIME ENVIRONMENT.
#
# The canonical external-PostgreSQL template is:
#   deploy/.env.controlled.example
# The canonical local-PostgreSQL template is:
#   deploy/.env.controlled.local-postgres.example
#
# Production-local deploy/.env.prod files must be preserved during migration and
# must never be overwritten automatically. Prepare a new controlled env file,
# validate it, and cut over separately.

NEXUS_ENV_TEMPLATE_RETIRED=true
NEXUS_CANONICAL_EXTERNAL_ENV_TEMPLATE=deploy/.env.controlled.example
NEXUS_CANONICAL_LOCAL_ENV_TEMPLATE=deploy/.env.controlled.local-postgres.example
