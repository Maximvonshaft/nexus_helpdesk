{
  "name": "helpdesk-suite-webapp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "e2e": "playwright test",
    "lint": "eslint .",
    "test": "node --test tests/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "architecture": "node scripts/assert-frontend-architecture.mjs && node scripts/assert-http-transport-authority.mjs",
    "verify": "npm run architecture && npm run lint && npm run typecheck && npm test && npm run build && node scripts/assert-route-splitting.mjs",
    "size-report": "node scripts/size-report.mjs"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "9.2.0",
    "@mui/material": "9.2.0",
    "@tanstack/react-query": "^5.90.0",
    "@tanstack/react-router": "^1.130.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-is": "18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.55.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.46.2",
    "vite": "^8.1.4"
  },
  "overrides": {
    "react-is": "18.3.1"
  }
}
