# Optional Tracking Fact MVP environment overlay.
# Keep disabled by default. Copy these values into the target runtime env only after
# the speedaf_lookup tool contract and PII redaction behavior are verified.

# Bridge-side read-only tool endpoint.
OPENCLAW_BRIDGE_TRACKING_LOOKUP_ENABLED=false
OPENCLAW_BRIDGE_TRACKING_LOOKUP_METHOD=tools.call
OPENCLAW_BRIDGE_TRACKING_LOOKUP_TOOL_NAME=speedaf-support__speedaf_lookup

# NexusDesk WebChat Tracking Fact controls.
WEBCHAT_TRACKING_FACT_LOOKUP_ENABLED=false
WEBCHAT_TRACKING_FACT_SOURCE=openclaw_bridge
WEBCHAT_TRACKING_FACT_TIMEOUT_SECONDS=8
WEBCHAT_TRACKING_FACT_REDACTION_ENABLED=true
WEBCHAT_TRACKING_FACT_CARD_ENABLED=false

# Required safety posture for Phase 1.
OPENCLAW_BRIDGE_AI_REPLY_ENABLED=true
OPENCLAW_BRIDGE_ALLOW_WRITES=false
ENABLE_OUTBOUND_DISPATCH=false
OUTBOUND_PROVIDER=disabled
WEBCHAT_STATIC_QUICK_REPLIES_MODE=off
