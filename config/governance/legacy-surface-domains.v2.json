{
  "schema": "nexus.legacy-surface.registry.v2",
  "registry_version": "2026-07-19.1",
  "coverage": "current_tracked_tree_classification_under_compatibility_lifecycle",
  "enforcement": "fail_closed",
  "finding_limit": 100,
  "max_text_bytes": 262144,
  "allowed_dispositions": [
    "active_authority",
    "active_compatibility",
    "data_migration_dependency",
    "generated_or_vendor",
    "protected_history",
    "safe_to_remove",
    "unknown_fail_closed"
  ],
  "domains": [
    {
      "id": "external_channel_persistence",
      "owner_issue": 572,
      "disposition": "data_migration_dependency",
      "deletion_authorized": false,
      "rationale": "ExternalChannel runtime and mutations are retired. Remaining model, migration and bounded read-only names are protected only until an explicitly authorized data export and destructive schema retirement is executed.",
      "prerequisites": [
        "zero_new_writes",
        "zero_runtime_callers",
        "historical_export",
        "restore_rehearsal",
        "explicit_destructive_retirement_authorization"
      ],
      "selectors": {
        "paths": [],
        "globs": [
          "*external_channel*",
          "**/*external_channel*",
          "*external-channel*",
          "**/*external-channel*"
        ],
        "path_regexes": [],
        "content_rules": []
      },
      "authoritative_refs": [
        "config:compatibility-lifecycle.v1",
        "issue:#572"
      ]
    },
    {
      "id": "application_settings_composition",
      "owner_issue": 570,
      "disposition": "active_authority",
      "deletion_authorized": false,
      "rationale": "Application composition and Settings are active runtime authorities, not legacy surfaces.",
      "prerequisites": [],
      "selectors": {
        "paths": [
          "backend/app/main.py",
          "backend/app/settings.py",
          "backend/app/settings_groups.py",
          "backend/app/bootstrap/routers.py"
        ],
        "globs": [],
        "path_regexes": [],
        "content_rules": []
      },
      "authoritative_refs": [
        "docs:codebase-rationalization-inventory"
      ]
    },
    {
      "id": "lite_api_authority",
      "owner_issue": 650,
      "disposition": "active_authority",
      "deletion_authorized": false,
      "rationale": "The Lite API is an actively consumed bounded read model. It is not a fallback or second product authority.",
      "prerequisites": [],
      "selectors": {
        "paths": [
          "backend/app/api/lite.py",
          "backend/app/services/canonical_lite_service.py",
          "backend/app/services/lite_service.py"
        ],
        "globs": [],
        "path_regexes": [],
        "content_rules": []
      },
      "authoritative_refs": [
        "config:service-authority.v1"
      ]
    },
    {
      "id": "protected_alembic_history",
      "owner_issue": 532,
      "disposition": "protected_history",
      "deletion_authorized": false,
      "rationale": "Alembic revisions are executable schema history required for deterministic empty-database upgrade, restore and rollback.",
      "prerequisites": [
        "approved_migration_squash_strategy",
        "empty_database_upgrade_proof",
        "restore_and_rollback_rehearsal"
      ],
      "selectors": {
        "paths": [],
        "globs": [
          "backend/alembic/versions/*.py"
        ],
        "path_regexes": [],
        "content_rules": []
      },
      "authoritative_refs": [
        "issue:#532",
        "docs:migration-policy"
      ]
    },
    {
      "id": "protected_versioned_contracts",
      "owner_issue": 650,
      "disposition": "active_authority",
      "deletion_authorized": false,
      "rationale": "Versioned machine contracts identify schemas and are not parallel implementations.",
      "prerequisites": [
        "consumer_inventory",
        "replacement_contract",
        "backward_compatibility_or_explicit_break"
      ],
      "selectors": {
        "paths": [],
        "globs": [],
        "path_regexes": [
          "(?i)^config/(?:[^/]+/)*[^/]+\\.v[0-9]+\\.json$",
          "(?i)^webapp/design/(?:[^/]+/)*[^/]+\\.v[0-9]+\\.json$",
          "(?i)^backend/app/config/(?:[^/]+/)*[^/]+\\.v[0-9]+\\.json$",
          "(?i)^backend/evals/(?:[^/]+/)*[^/]+\\.v[0-9]+\\.json$"
        ],
        "content_rules": []
      },
      "authoritative_refs": [
        "issue:#650",
        "issue:#613",
        "issue:#585"
      ]
    }
  ],
  "discovery_rules": [
    {
      "id": "external_channel_path_marker",
      "path_regex": "(?i)external[_-]channel",
      "path_globs": [],
      "content_markers": [],
      "content_path_globs": [],
      "allowed_domain_ids": [
        "external_channel_persistence",
        "protected_alembic_history"
      ],
      "allow_multiple_domains": true
    },
    {
      "id": "alembic_revision_path",
      "path_regex": null,
      "path_globs": [
        "backend/alembic/versions/*.py"
      ],
      "content_markers": [],
      "content_path_globs": [],
      "allowed_domain_ids": [
        "protected_alembic_history",
        "external_channel_persistence"
      ],
      "allow_multiple_domains": true
    },
    {
      "id": "versioned_contract_path",
      "path_regex": "(?i)\\.v[0-9]+\\.json$",
      "path_globs": [],
      "content_markers": [],
      "content_path_globs": [],
      "allowed_domain_ids": [
        "protected_versioned_contracts"
      ],
      "allow_multiple_domains": false
    }
  ]
}
