# Speedaf express track query / hybrid tracking integration example.
# Copy these keys into the real production env only after credentials are issued and validated.
# Do not commit real appCode/secretKey values.

# Recommended controlled-pilot mode:
# - /open-api/mcp/order/query remains the primary current-status source.
# - /open-api/express/track/query enriches recent tracking events only.
# - If track/query fails or is not configured, WebChat falls back to order/query.
WEBCHAT_TRACKING_FACT_LOOKUP_ENABLED=true
WEBCHAT_TRACKING_FACT_SOURCE=speedaf_hybrid
WEBCHAT_TRACKING_FACT_REDACTION_ENABLED=true
WEBCHAT_TRACKING_FACT_CARD_ENABLED=true
WEBCHAT_TRACKING_FACT_TIMEOUT_SECONDS=8

# Direct full-history mode exists but is not recommended as the first production switch:
# WEBCHAT_TRACKING_FACT_SOURCE=speedaf_track_query

# /open-api/express/track/query uses signed requests and encrypted response.data.
# Production example: https://apis.speedaf.com
# UAT example: https://uat-api.speedaf.com
SPEEDAF_TRACK_QUERY_ENABLED=false
SPEEDAF_TRACK_QUERY_BASE_URL=https://apis.speedaf.com
SPEEDAF_TRACK_QUERY_APP_CODE=PLACEHOLDER_SPEEDAF_TRACK_QUERY_APP_CODE
SPEEDAF_TRACK_QUERY_SECRET_KEY=PLACEHOLDER_8_BYTE_SPEEDAF_TRACK_QUERY_SECRET_KEY
SPEEDAF_TRACK_QUERY_CONTENT_TYPE=text/plain
SPEEDAF_TRACK_QUERY_TIMEOUT_SECONDS=8
