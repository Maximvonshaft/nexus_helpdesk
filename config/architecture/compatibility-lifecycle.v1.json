{
  "schema": "nexus.compatibility-lifecycle.v1",
  "policy": "This is the sole compatibility lifecycle authority. Compatibility assets may document bounded product boundaries or subordinate discovery, but may not create retired state, enqueue retired work, send provider traffic, mutate schema, own secrets, or define a parallel product.",
  "assets": [
    {
      "path": "backend/app/static/webchat",
      "kind": "separate-public-product-surface",
      "owner": "customer-channel-platform",
      "replacement": null,
      "introduced_at": "2026-07-18",
      "remove_after": null,
      "constraints": [
        "not-an-operator-console",
        "provider-governed-customer-messages"
      ]
    },
    {
      "path": "config/governance/legacy-surface-domains.v2.json",
      "kind": "subordinate-discovery-registry",
      "owner": "architecture-governance",
      "replacement": "config/architecture/compatibility-lifecycle.v1.json",
      "introduced_at": "2026-07-19",
      "remove_after": null,
      "constraints": [
        "subordinate-only",
        "fail-closed",
        "runtime-head-bound",
        "no-independent-policy"
      ]
    }
  ],
  "detailed_registry": "config/governance/legacy-surface-domains.v2.json",
  "enforcement_entrypoint": "scripts/ci/check_legacy_surface_registry.py"
}
