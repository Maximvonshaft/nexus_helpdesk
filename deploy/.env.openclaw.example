# Optional OpenClaw legacy integration override.
# OpenClaw is not required for default production and must not enable writes,
# inbound auto-sync, or event-driver workers unless explicitly approved.

OPENCLAW_INTEGRATION_ENABLED=true
OPENCLAW_DEPLOYMENT_MODE=remote_gateway
OPENCLAW_TRANSPORT=mcp
OPENCLAW_MCP_COMMAND=openclaw
OPENCLAW_MCP_URL=wss://your-openclaw-gateway.example/mcp
OPENCLAW_MCP_TOKEN_FILE=/run/secrets/openclaw_mcp_token

OPENCLAW_BRIDGE_ENABLED=false
OPENCLAW_BRIDGE_AI_REPLY_ENABLED=false
OPENCLAW_BRIDGE_ALLOW_WRITES=false
OPENCLAW_SYNC_ENABLED=false
OPENCLAW_INBOUND_AUTO_SYNC_ENABLED=false
OPENCLAW_EVENT_DRIVER_ENABLED=false

OPENCLAW_RESPONSES_URL=
OPENCLAW_RESPONSES_TOKEN_FILE=
OPENCLAW_RESPONSES_STREAM_URL=
OPENCLAW_RESPONSES_STREAM_TOKEN_FILE=
