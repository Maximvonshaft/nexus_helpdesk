# RETIRED COMPATIBILITY PATH — DO NOT COPY AS A RUNTIME ENVIRONMENT.
#
# Candidate and controlled deployments now share one topology and one external
# evidence contract. Use deploy/.env.controlled.example and
# deploy/docker-compose.controlled.yml. The old candidate-specific sidecar,
# external network and service names no longer exist.

NEXUS_ENV_TEMPLATE_RETIRED=true
NEXUS_DATABASE_TOPOLOGY=external
NEXUS_CANONICAL_ENV_TEMPLATE=deploy/.env.controlled.example
