{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nexus.private_ai_runtime.deployment_manifest.v1",
  "title": "Nexus Private AI Runtime Deployment Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "manifest_version", "release_id", "source", "capability_contract",
    "host_requirements", "immutable_release", "mutable_state", "secret_references",
    "images", "models", "services", "acceptance", "rollback", "drift"
  ],
  "properties": {
    "schema": {"const": "nexus.private_ai_runtime.deployment_manifest.v1"},
    "manifest_version": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}\\.[0-9]+$"},
    "release_id": {"$ref": "#/$defs/releaseId"},
    "source": {
      "type": "object", "additionalProperties": false,
      "required": ["repository", "commit_sha", "tree_sha"],
      "properties": {
        "repository": {"type": "string", "pattern": "^[^/\\s]+/[^/\\s]+$"},
        "commit_sha": {"$ref": "#/$defs/sha40"},
        "tree_sha": {"$ref": "#/$defs/sha40"}
      }
    },
    "capability_contract": {
      "type": "object", "additionalProperties": false,
      "required": ["schema", "path", "sha256"],
      "properties": {
        "schema": {"const": "nexus.ai_runtime.capabilities.v1"},
        "path": {"$ref": "#/$defs/relativePath"},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "host_requirements": {
      "type": "object", "additionalProperties": false,
      "required": ["os_family", "architecture", "gpu_vendor", "min_gpu_vram_mib", "min_disk_free_mib", "driver_constraint"],
      "properties": {
        "os_family": {"const": "linux"},
        "architecture": {"enum": ["x86_64", "aarch64"]},
        "gpu_vendor": {"const": "nvidia"},
        "min_gpu_vram_mib": {"type": "integer", "minimum": 1024, "maximum": 1048576},
        "min_disk_free_mib": {"type": "integer", "minimum": 1024, "maximum": 100000000},
        "driver_constraint": {"type": "string", "minLength": 1, "maxLength": 128}
      }
    },
    "immutable_release": {
      "type": "object", "additionalProperties": false,
      "required": ["root", "artifacts"],
      "properties": {
        "root": {"$ref": "#/$defs/absolutePath"},
        "artifacts": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/artifact"}}
      }
    },
    "mutable_state": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/mutableState"}},
    "secret_references": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/secretReference"}},
    "images": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/image"}},
    "models": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/model"}},
    "services": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/service"}},
    "acceptance": {
      "type": "object", "additionalProperties": false,
      "required": ["commands", "required_checks", "network_mode"],
      "properties": {
        "commands": {"$ref": "#/$defs/commands"},
        "required_checks": {
          "type": "array", "minItems": 6, "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 64},
          "allOf": [
            {"contains": {"const": "gpu_placement"}},
            {"contains": {"const": "generation_hot_path"}},
            {"contains": {"const": "retrieval"}},
            {"contains": {"const": "voice"}},
            {"contains": {"const": "metrics"}},
            {"contains": {"const": "model_identity"}}
          ]
        },
        "network_mode": {"enum": ["offline", "read_only"]}
      }
    },
    "rollback": {
      "type": "object", "additionalProperties": false,
      "required": ["target_release_id", "package_path", "sha256", "commands", "destructive"],
      "properties": {
        "target_release_id": {"$ref": "#/$defs/releaseId"},
        "package_path": {"$ref": "#/$defs/absolutePath"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "commands": {"$ref": "#/$defs/commands"},
        "destructive": {"const": false}
      }
    },
    "drift": {
      "type": "object", "additionalProperties": false,
      "required": ["tracked_paths", "result_path", "interval_seconds", "fail_closed"],
      "properties": {
        "tracked_paths": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/absolutePath"}},
        "result_path": {"$ref": "#/$defs/absolutePath"},
        "interval_seconds": {"type": "integer", "minimum": 60, "maximum": 86400},
        "fail_closed": {"const": true}
      }
    }
  },
  "$defs": {
    "sha40": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9_-]{2,63}$"},
    "releaseId": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{4,127}$"},
    "absolutePath": {"type": "string", "pattern": "^/(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
    "relativePath": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
    "artifact": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "sha256", "mode"],
      "properties": {"path": {"$ref": "#/$defs/relativePath"}, "sha256": {"$ref": "#/$defs/sha256"}, "mode": {"type": "string", "pattern": "^0[0-7]{3}$"}}
    },
    "mutableState": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "path", "purpose", "authoritative", "backup_required"],
      "properties": {"id": {"$ref": "#/$defs/id"}, "path": {"$ref": "#/$defs/absolutePath"}, "purpose": {"type": "string", "minLength": 1, "maxLength": 128}, "authoritative": {"const": false}, "backup_required": {"type": "boolean"}}
    },
    "secretReference": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "kind", "reference", "required"],
      "properties": {"id": {"$ref": "#/$defs/id"}, "kind": {"enum": ["file", "secret_store"]}, "reference": {"type": "string", "minLength": 1, "maxLength": 512}, "required": {"type": "boolean"}}
    },
    "image": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "reference"],
      "properties": {"id": {"$ref": "#/$defs/id"}, "reference": {"type": "string", "pattern": "^[^\\s@]+@sha256:[0-9a-f]{64}$"}}
    },
    "model": {
      "type": "object", "additionalProperties": false,
      "required": ["capability", "model_id", "revision", "sha256"],
      "properties": {"capability": {"$ref": "#/$defs/id"}, "model_id": {"type": "string", "minLength": 1, "maxLength": 256}, "revision": {"type": "string", "minLength": 1, "maxLength": 256}, "sha256": {"$ref": "#/$defs/sha256"}}
    },
    "service": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "manager", "definition_path", "sha256"],
      "properties": {"name": {"$ref": "#/$defs/id"}, "manager": {"enum": ["systemd", "compose"]}, "definition_path": {"$ref": "#/$defs/relativePath"}, "sha256": {"$ref": "#/$defs/sha256"}}
    },
    "commands": {
      "type": "array", "minItems": 1,
      "items": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1, "maxLength": 1024}}
    }
  }
}
