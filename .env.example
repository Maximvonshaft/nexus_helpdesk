
# Provider Runtime
PROVIDER_RUNTIME_ENABLED=true
PROVIDER_CREDENTIAL_ENCRYPTION_KEY_FILE=/run/nexus/provider_credential_key
# PROVIDER_CREDENTIAL_ENCRYPTION_KEY is development/test only; production must use PROVIDER_CREDENTIAL_ENCRYPTION_KEY_FILE.
# PROVIDER_CREDENTIAL_ENCRYPTION_KEY=

# Outbound Email SMTP account secrets
OUTBOUND_EMAIL_ENCRYPTION_KEY_FILE=/run/nexus/outbound_email_encryption_key
# OUTBOUND_EMAIL_ENCRYPTION_KEY is development/test only; production must use OUTBOUND_EMAIL_ENCRYPTION_KEY_FILE.
# OUTBOUND_EMAIL_ENCRYPTION_KEY=

CODEX_OAUTH_DEVICE_FLOW_ENABLED=false
CODEX_OAUTH_AUTH_BASE_URL=
CODEX_OAUTH_CLIENT_ID=
CODEX_OAUTH_DEVICE_USERCODE_PATH=
CODEX_OAUTH_DEVICE_TOKEN_PATH=
CODEX_OAUTH_TOKEN_PATH=

CODEX_APP_SERVER_PROVIDER_ENABLED=false
CODEX_APP_SERVER_BRIDGE_URL=http://172.18.0.1:18794/reply
CODEX_APP_SERVER_LOGIN_URL=http://172.18.0.1:18794/login
CODEX_APP_SERVER_TOKEN_FILE=/run/nexus/codex_app_server_bridge_token
CODEX_APP_SERVER_BRIDGE_MODE=real
CODEX_APP_SERVER_REAL_UPSTREAM_URL=http://127.0.0.1:18795/reply
CODEX_APP_SERVER_REPLY_GENERATION_BACKEND=codex_app_server
CODEX_APP_SERVER_CANARY_PERCENT=1
CODEX_APP_SERVER_KILL_SWITCH=false

WEBCHAT_FAST_AI_PROVIDER=provider_runtime
WEBCHAT_FAST_AI_FALLBACK_PROVIDER=rule_engine

OPENAI_RESPONSES_ENABLED=false
OPENAI_API_KEY_FILE=/run/nexus/openai_api_key

ANTHROPIC_ENABLED=false
ANTHROPIC_API_KEY_FILE=/run/nexus/anthropic_api_key

GEMINI_ENABLED=false
GEMINI_API_KEY_FILE=/run/nexus/gemini_api_key

OPENROUTER_ENABLED=false
OPENROUTER_API_KEY_FILE=/run/nexus/openrouter_api_key

# Codex / Code X OAuth credential broker
CODEX_OAUTH_AUTHORIZATION_CODE_ENABLED=false
CODEX_OAUTH_AUTHORIZATION_URL=
CODEX_OAUTH_REDIRECT_URI=
CODEX_OAUTH_REVOKE_URL=
CODEX_OAUTH_ALLOWED_SCOPES=
CODEX_OAUTH_DEFAULT_SCOPES=
CODEX_OAUTH_CLIENT_SECRET_FILE=
# CODEX_OAUTH_CLIENT_SECRET is development/test only; production must use CODEX_OAUTH_CLIENT_SECRET_FILE.
CODEX_OAUTH_CLIENT_SECRET=
CODEX_OAUTH_STATE_TTL_SECONDS=600
CODEX_OAUTH_INCLUDE_NONCE=true
CODEX_OAUTH_CALLBACK_SUCCESS_REDIRECT_URL=
CODEX_OAUTH_CALLBACK_FAILURE_REDIRECT_URL=
PROVIDER_RUNTIME_DEFAULT_TENANT_ID=default
