APP_ENV=development
DATABASE_URL=sqlite:///./helpdesk.db
# Production example:
# DATABASE_URL=postgresql+psycopg://helpdesk:password@localhost:5432/helpdesk
SECRET_KEY=change-me
JWT_ISSUER=helpdesk-suite
JWT_AUDIENCE=helpdesk-suite-users
ACCESS_TOKEN_EXPIRE_HOURS=12
AUTO_INIT_DB=false
SEED_DEMO_DATA=false
ALLOW_DEV_AUTH=false

STORAGE_BACKEND=local
UPLOAD_ROOT=./uploads
MAX_UPLOAD_BYTES=10485760
ALLOWED_UPLOAD_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf,text/plain,text/markdown,text/csv,text/html,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet
ALLOWED_UPLOAD_EXTENSIONS=.jpg,.jpeg,.png,.webp,.pdf,.txt,.md,.markdown,.csv,.html,.htm,.docx,.xlsx

ENABLE_OUTBOUND_DISPATCH=false
OUTBOUND_PROVIDER=disabled
OPENCLAW_BIN=
OPENCLAW_TRANSPORT=mcp
OPENCLAW_MCP_COMMAND=openclaw
OPENCLAW_MCP_URL=
OPENCLAW_MCP_TOKEN_FILE=
OPENCLAW_MCP_PASSWORD_FILE=
OPENCLAW_MCP_CLAUDE_CHANNEL_MODE=off
OUTBOX_BATCH_SIZE=50
OUTBOX_LOCK_SECONDS=300
OUTBOX_MAX_RETRIES=3
JOB_BATCH_SIZE=25
JOB_LOCK_SECONDS=300
JOB_MAX_RETRIES=3
WORKER_POLL_SECONDS=2

ALLOW_LEGACY_INTEGRATION_API_KEY=false
INTEGRATION_API_KEY=
INTEGRATION_DEFAULT_RATE_LIMIT_PER_MINUTE=60
INTEGRATION_REQUIRE_IDEMPOTENCY_KEY=true

LOGIN_MAX_FAILURES=5
LOGIN_LOCK_MINUTES=15
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

S3_BUCKET=
S3_ENDPOINT_URL=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PRESIGN_EXPIRY_SECONDS=900
LOG_JSON=true
METRICS_ENABLED=false
METRICS_TOKEN=replace-with-strong-metrics-token

# Cloud app + local/remote OpenClaw Gateway recommended production topology
OPENCLAW_DEPLOYMENT_MODE=remote_gateway
OPENCLAW_CLI_FALLBACK_ENABLED=false
OPENCLAW_SYNC_ENABLED=true
OPENCLAW_EVENT_DRIVER_ENABLED=true
OPENCLAW_SYNC_DAEMON_STALE_SECONDS=90
OPENCLAW_SYNC_BATCH_SIZE=50
OPENCLAW_SYNC_STALE_SECONDS=120
OPENCLAW_SYNC_TRANSCRIPT_LIMIT=100
OPENCLAW_SYNC_POLL_TIMEOUT_SECONDS=15
OPENCLAW_SESSION_DM_SCOPE=per-account-channel-peer
REQUIRE_PROMETHEUS_CLIENT_IN_PRODUCTION=true
REQUEST_ID_HEADER=X-Request-Id
LOG_JSON=true
METRICS_ENABLED=false
METRICS_TOKEN=replace-with-strong-metrics-token
TRUSTED_PROXY_IPS=127.0.0.1/32,::1/128
OPENCLAW_ATTACHMENT_URL_FETCH_ENABLED=false
OPENCLAW_ATTACHMENT_ALLOWED_HOSTS=
OPENCLAW_ATTACHMENT_FETCH_TIMEOUT_SECONDS=10
OPENCLAW_ATTACHMENT_MAX_DOWNLOAD_BYTES=10485760
OPENCLAW_ATTACHMENT_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf,text/plain,application/octet-stream

# WebCall AI infrastructure skeleton. Defaults are fail-closed: no customer
# traffic, no recording, no risky write actions, and fake providers only.
WEBCALL_AI_PRODUCTION_ENABLED=false
WEBCALL_AI_AGENT_ENABLED=false
WEBCALL_AI_KILL_SWITCH=false
WEBCALL_AI_PUBLIC_ROLLOUT_MODE=off
WEBCALL_AI_ALLOWED_ORIGINS=https://www.leakle.com
WEBCALL_AI_AGENT_LEASE_SECONDS=45
WEBCALL_AI_MIN_UTTERANCE_SECONDS=1
WEBCALL_AI_MAX_UTTERANCE_SECONDS=12
WEBCALL_AI_SILENCE_END_MS=700
WEBCALL_AI_AUDIO_SAMPLE_RATE=48000
WEBCALL_AI_PROVIDER_PROFILE=fake
WEBCALL_AI_MAX_ACTIVE_SESSIONS=3
WEBCALL_AI_MAX_TURNS_PER_SESSION=10
WEBCALL_AI_MAX_SESSION_SECONDS=600
WEBCALL_AI_RECORD_RAW_AUDIO=false
WEBCALL_AI_ALLOW_SPEEDAF_WORK_ORDER=false
WEBCALL_AI_ALLOW_CANCEL=false
WEBCALL_AI_ALLOW_ADDRESS_UPDATE=false
WEBCHAT_VOICE_PROVIDER=mock
WEBCHAT_VOICE_ENABLED=false
WEBCHAT_KNOWLEDGE_REPLY_MODE=ai_grounded
WEBCHAT_VOICE_ALLOWED_PATH_PREFIXES=/webchat,/webchat/voice,/webcall,/webcall-ai,/webchat-voice
WEBCHAT_VOICE_CONNECT_SRC=wss://voice.leakle.com
WEBCHAT_WS_ENABLED=false
WEBCHAT_WS_PUBLIC_ENABLED=false
WEBCHAT_WS_ADMIN_ENABLED=false
WEBCHAT_WS_BROKER=database
WEBCHAT_WS_REPLAY_POLL_MS=500
WEBCHAT_WS_FALLBACK_POLL_MS=4000
WEBCHAT_WS_HEARTBEAT_MS=25000
WEBCHAT_WS_HELLO_TIMEOUT_MS=5000
WEBCHAT_WS_MAX_CONNECTIONS=1000
WEBCHAT_WS_MAX_CONNECTIONS_PER_USER=10
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_API_KEY_FILE=
LIVEKIT_API_SECRET_FILE=
STT_PROVIDER=fake
LLM_PROVIDER=fake
TTS_PROVIDER=fake
STT_ENDPOINT=
STT_API_KEY_FILE=
LLM_ENDPOINT=
LLM_API_KEY_FILE=
TTS_ENDPOINT=
TTS_API_KEY_FILE=
TRACKING_LOOKUP_ENDPOINT=
TRACKING_LOOKUP_API_KEY_FILE=
