+def _ensure_voice_ticket(db: Session, *, conversation: WebchatConversation) -> Ticket:
+    """Create the formal support ticket only when a customer starts a voice call.
+
+    Text chat remains conversation-first. The existing voice operator surface is
+    ticket-addressed, so the voice action is the explicit business boundary that
+    creates (or reuses) the ticket. The canonical OSR ticket authority supplies
+    locking, idempotency, audit events, and the conversation linkage.
+    """
+
+    if conversation.ticket_id is not None:
+        ticket = db.get(Ticket, conversation.ticket_id)
+        if ticket is None:
+            raise HTTPException(
+                status_code=status.HTTP_409_CONFLICT,
+                detail="voice_conversation_ticket_missing",
+            )
+        return ticket
+
+    control = (
+        db.query(ConversationControl)
+        .filter(ConversationControl.conversation_id == conversation.id)
+        .one_or_none()
+    )
+    customer = (
+        db.get(Customer, control.customer_id)
+        if control is not None and control.customer_id is not None
+        else None
+    )
+    case_context = CaseContext(
+        conversation_id=conversation.id,
+        channel=conversation.channel_key or SourceChannel.web_chat.value,
+        country_code=control.country_code if control is not None else None,
+        issue_type="live_voice_support",
+        customer_claim_summary="Customer requested live voice support.",
+        ai_actions_taken=["live_voice_requested"],
+    )
+    result = create_or_reuse_ticket_from_case_context(
+        db,
+        case_context=case_context,
+        customer=customer,
+        conversation=conversation,
+        source_channel=SourceChannel.web_chat,
+        title=f"Live voice support · {conversation.visitor_name or conversation.public_id}"[:200],
+        description="Customer initiated a live voice support session from WebChat.",
+        priority=TicketPriority.medium,
+        issue_type="live_voice_support",
+    )
+    return result.ticket
+
+
@@ -374,0 +428 @@
