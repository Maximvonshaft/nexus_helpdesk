# NexusDesk production environment template. Do not commit real values.
# Copy to deploy/.env.prod on the server and fill real values there.

APP_ENV=production
SECRET_KEY=replace-with-a-long-random-value
RUNTIME_CONTRACT_SIGNING_SECRET=replace-with-a-separate-long-random-contract-signing-secret
JWT_ISSUER=nexusdesk
JWT_AUDIENCE=nexusdesk-users
ACCESS_TOKEN_EXPIRE_HOURS=12

# Runtime build identity. Deployment scripts should export these before build/up.
GIT_SHA=unknown
BUILD_TIME=unknown
IMAGE_TAG=nexusdesk/helpdesk:server
APP_VERSION=server
FRONTEND_BUILD_SHA=unknown

# Host runtime paths. Keep real secret files on the server, outside git.
NEXUSDESK_RUNTIME_SECRETS_DIR=/opt/nexus_helpdesk/deploy/runtime_secrets
NEXUSDESK_UPLOADS_DIR=/opt/nexus_helpdesk/data/uploads

# Database. Default server compose uses the internal postgres service.
POSTGRES_DB=nexusdesk
POSTGRES_USER=nexusdesk
POSTGRES_PASSWORD=replace-with-strong-postgres-password
DATABASE_URL=postgresql+psycopg://nexusdesk:replace-with-strong-postgres-password@postgres:5432/nexusdesk
DATABASE_ECHO=false
AUTO_INIT_DB=false
SEED_DEMO_DATA=false
ALLOW_DEV_AUTH=false
ALLOW_LEGACY_INTEGRATION_API_KEY=false

# Reverse proxy / CORS.
# Standard controlled-pilot API entrypoint is host 127.0.0.1:18081 -> app container 8080.
# Edge nginx remains optional behind the edge-nginx compose profile.
APP_HOST_PORT=18081
ALLOWED_ORIGINS=https://your-helpdesk-domain.example
TRUSTED_PROXY_IPS=127.0.0.1

# Storage.
# Strict production recommendation: s3.
# Controlled pilot fallback: STORAGE_BACKEND=local with ../data/uploads mounted to /app/backend/uploads and backed up daily.
STORAGE_BACKEND=s3
UPLOAD_ROOT=/app/backend/uploads
S3_BUCKET=replace-with-bucket
S3_REGION=auto
S3_ENDPOINT_URL=https://s3.example.com
S3_ACCESS_KEY=replace-with-access-key
S3_SECRET_KEY=replace-with-secret-key
S3_PRESIGN_EXPIRY_SECONDS=900

# Legacy ExternalChannel compatibility. Keep disabled; runtime bridge/MCP/CLI are retired.
EXTERNAL_CHANNEL_DEPLOYMENT_MODE=disabled
EXTERNAL_CHANNEL_TRANSPORT=disabled
EXTERNAL_CHANNEL_MCP_COMMAND=
EXTERNAL_CHANNEL_EXTRA_PATHS=
EXTERNAL_CHANNEL_MCP_URL=
EXTERNAL_CHANNEL_MCP_TOKEN_FILE=
EXTERNAL_CHANNEL_MCP_PASSWORD_FILE=
EXTERNAL_CHANNEL_CLI_FALLBACK_ENABLED=false
EXTERNAL_CHANNEL_BRIDGE_ENABLED=false
EXTERNAL_CHANNEL_BRIDGE_URL=
EXTERNAL_CHANNEL_BRIDGE_AI_REPLY_ENABLED=false
EXTERNAL_CHANNEL_BRIDGE_ALLOW_WRITES=false
EXTERNAL_CHANNEL_SYNC_ENABLED=false
EXTERNAL_CHANNEL_INBOUND_AUTO_SYNC_ENABLED=false
EXTERNAL_CHANNEL_INBOUND_SYNC_LIMIT=10
EXTERNAL_CHANNEL_INBOUND_SYNC_MESSAGE_LIMIT=20
EXTERNAL_CHANNEL_INBOUND_SYNC_INCLUDE_GROUPS=false
EXTERNAL_CHANNEL_EVENT_DRIVER_ENABLED=false
ENABLE_OUTBOUND_DISPATCH=false
OUTBOUND_PROVIDER=disabled
OUTBOUND_EMAIL_ENCRYPTION_KEY_FILE=/run/nexus/outbound_email_encryption_key
# Keep false until an admin has configured SMTP, run a successful test-send,
# and the rollout owner accepts real Email dispatch pilot risk.
OUTBOUND_EMAIL_PRODUCTION_PILOT_ENABLED=false
OUTBOUND_EMAIL_TEST_SEND_MAX_AGE_HOURS=24

# Queues / workers.
OUTBOX_BATCH_SIZE=50
OUTBOX_LOCK_SECONDS=300
OUTBOX_MAX_RETRIES=3
JOB_BATCH_SIZE=25
JOB_LOCK_SECONDS=300
JOB_MAX_RETRIES=3
WORKER_POLL_SECONDS=2

# Webchat.
WEBCHAT_ALLOWED_ORIGINS=https://your-customer-site.example
WEBCHAT_ALLOW_NO_ORIGIN=false
WEBCHAT_ALLOW_LEGACY_TOKEN_TRANSPORT=false
WEBCHAT_RATE_LIMIT_BACKEND=database
WEBCHAT_RATE_LIMIT_WINDOW_SECONDS=60
WEBCHAT_RATE_LIMIT_MAX_REQUESTS=20
WEBCHAT_AI_AUTO_REPLY_MODE=runtime

# Metrics / observability.
LOG_JSON=true
METRICS_ENABLED=false
METRICS_TOKEN=
REQUIRE_PROMETHEUS_CLIENT_IN_PRODUCTION=true

# Legacy inbound attachment compatibility.
EXTERNAL_CHANNEL_ATTACHMENT_URL_FETCH_ENABLED=false
EXTERNAL_CHANNEL_ATTACHMENT_ALLOWED_HOSTS=
EXTERNAL_CHANNEL_ATTACHMENT_FETCH_TIMEOUT_SECONDS=10
EXTERNAL_CHANNEL_ATTACHMENT_MAX_DOWNLOAD_BYTES=10485760

# WebChat AI Runtime
WEBCHAT_AI_ENABLED=true
WEBCHAT_AI_HISTORY_TURNS=5
WEBCHAT_AI_TURN_DEBOUNCE_SECONDS=0.05
WEBCHAT_AI_WORKER_POLL_SECONDS=0.10
WEBCHAT_AI_WORKER_BUSY_POLL_SECONDS=0.02
WEBCHAT_WS_ENABLED=true
WEBCHAT_WS_PUBLIC_ENABLED=true
WEBCHAT_WS_ADMIN_ENABLED=true
WEBCHAT_WS_REPLAY_POLL_MS=100
WEBCHAT_WS_FALLBACK_POLL_MS=4000

# WebChat live voice. The browser connects only to same-origin
# /webchat/live/ws; Nexus proxies to the private AI Runtime server-side.
WEBCHAT_VOICE_PROVIDER=mock
WEBCHAT_VOICE_ENABLED=true
WEBCHAT_VOICE_ALLOWED_PATH_PREFIXES=/webchat,/api/webchat
WEBCHAT_VOICE_CONNECT_SRC=
WEBCHAT_VOICE_RECORDING_ENABLED=false
WEBCHAT_VOICE_TRANSCRIPTION_ENABLED=false
LIVE_VOICE_UPSTREAM_WS_URL=ws://ai-runtime.internal:18081/live/ws
LIVE_VOICE_UPSTREAM_HEALTH_URL=http://ai-runtime.internal:18081/live/health
LIVE_VOICE_UPSTREAM_TOKEN_FILE=/run/nexus/live_voice_token

# Provider Runtime
PROVIDER_RUNTIME_ENABLED=true
PROVIDER_CREDENTIAL_ENCRYPTION_KEY_FILE=/run/nexus/provider_credential_key
# DO NOT USE PLAIN TEXT ENCRYPTION KEY IN PRODUCTION
# PROVIDER_CREDENTIAL_ENCRYPTION_KEY=

# Private AI Runtime. Server-side only; never expose the token or base runtime
# URL in widget.js, customer pages, or browser runtime config.
PRIVATE_AI_RUNTIME_ENABLED=false
PRIVATE_AI_RUNTIME_BASE_URL=http://ai-runtime.internal:18081
PRIVATE_AI_RUNTIME_RAG_BASE_URL=http://ai-runtime-rag.internal:18081
PRIVATE_AI_RUNTIME_ALLOW_SHARED_RAG_MODEL=false
PRIVATE_AI_RUNTIME_TOKEN_FILE=/run/nexus/ai_runtime_token
PRIVATE_AI_RUNTIME_DIRECT_PATH=/api/chat
PRIVATE_AI_RUNTIME_RAG_PATH=/api/chat
PRIVATE_AI_RUNTIME_CHAT_MODE=direct
PRIVATE_AI_RUNTIME_REQUEST_SHAPE=ollama_chat
PRIVATE_AI_RUNTIME_DIRECT_MODEL=qwen2.5:3b
PRIVATE_AI_RUNTIME_RAG_MODEL=qwen3:4b
PRIVATE_AI_RUNTIME_DIRECT_MODEL_POLICY=fixed
PRIVATE_AI_RUNTIME_TIMEOUT_SECONDS=20
PRIVATE_AI_RUNTIME_MAX_PROMPT_CHARS=3500
PRIVATE_AI_RUNTIME_MAX_OUTPUT_CHARS=1200
PRIVATE_AI_RUNTIME_OLLAMA_KEEP_ALIVE=24h
PRIVATE_AI_RUNTIME_OLLAMA_NUM_PREDICT_SHORT=80
PRIVATE_AI_RUNTIME_OLLAMA_NUM_PREDICT_SERVICE=192
PRIVATE_AI_RUNTIME_OLLAMA_NUM_PREDICT_STANDARD=320
PRIVATE_AI_RUNTIME_OLLAMA_NUM_PREDICT_REPAIR=160
PRIVATE_AI_RUNTIME_OLLAMA_NUM_CTX_SHORT=2048
PRIVATE_AI_RUNTIME_OLLAMA_NUM_CTX_SERVICE=4096
PRIVATE_AI_RUNTIME_OLLAMA_NUM_CTX_STANDARD=4096
PRIVATE_AI_RUNTIME_OLLAMA_NUM_CTX_REPAIR=4096
PRIVATE_AI_RUNTIME_MAX_CONTRACT_REPAIR_ATTEMPTS=2
PRIVATE_AI_RUNTIME_WARMUP_INTERVAL_SECONDS=60

# Provider Runtime route.
PROVIDER_RUNTIME_PRIMARY_PROVIDER=private_ai_runtime
PROVIDER_RUNTIME_FALLBACK_PROVIDERS=[]
PROVIDER_RUNTIME_OUTPUT_CONTRACT=nexus.webchat_runtime_reply
PROVIDER_RUNTIME_TIMEOUT_MS=30000
PROVIDER_RUNTIME_TRAFFIC_MODE=canary
PROVIDER_RUNTIME_CANARY_PERCENT=100
PROVIDER_RUNTIME_KILL_SWITCH=false

PROVIDER_RUNTIME_DEFAULT_TENANT_ID=default

# Speedaf support-agent parity. Keep real app code/secret in server secret
# storage or server-only env files; never expose them to browsers.
WEBCHAT_TRACKING_FACT_SOURCE=speedaf_hybrid
WEBCHAT_TRACKING_FACT_LOOKUP_ENABLED=true
WEBCHAT_TRACKING_FACT_REDACTION_ENABLED=true
WEBCHAT_TRACKING_FACT_TIMEOUT_SECONDS=20
SPEEDAF_MCP_ENABLED=false
SPEEDAF_MCP_BASE_URL=https://apis.speedaf.com
SPEEDAF_MCP_APP_CODE=<speedaf-app-code>
SPEEDAF_MCP_SECRET_KEY=<speedaf-secret-key>
SPEEDAF_MCP_CUSTOMER_CODE=CH000001
SPEEDAF_MCP_PLATFORM_SOURCE=API KEY
SPEEDAF_MCP_LOOKUP_CALLER_ID=<support-lookup-caller-id>
SPEEDAF_MCP_CONTENT_TYPE=text/plain
SPEEDAF_MCP_DATA_MODE=string
SPEEDAF_MCP_REQUIRE_SIGN=false
SPEEDAF_TRACK_QUERY_ENABLED=false
SPEEDAF_TRACK_QUERY_BASE_URL=https://apis.speedaf.com
SPEEDAF_TRACK_QUERY_APP_CODE=<speedaf-app-code>
SPEEDAF_TRACK_QUERY_SECRET_KEY=<speedaf-secret-key>
SPEEDAF_TRACK_QUERY_CONTENT_TYPE=text/plain
SPEEDAF_WORK_ORDER_CREATE_ENABLED=false
SPEEDAF_UPDATE_ADDRESS_ENABLED=false
SPEEDAF_CANCEL_ENABLED=false
SPEEDAF_VOICE_CALLBACK_ENABLED=false

# Knowledge / RAG. Use this only if the AI Runtime or MCS gateway exposes an
# OpenAI-compatible /embeddings endpoint. If it only exposes /rag/search and
# /rag/upsert, keep Nexus pgvector retrieval enabled and route RAG answers
# through PRIVATE_AI_RUNTIME_CHAT_MODE=rag or auto until a native RAG adapter is
# approved.
KNOWLEDGE_EMBEDDINGS_ENABLED=true
KNOWLEDGE_EMBEDDING_PROVIDER=openai_compatible
KNOWLEDGE_EMBEDDING_BASE_URL=http://ai-runtime.internal:18081/v1
KNOWLEDGE_EMBEDDING_API_KEY_FILE=/run/nexus/ai_runtime_token
KNOWLEDGE_EMBEDDING_MODEL=BAAI/bge-m3
KNOWLEDGE_EMBEDDING_DIM=1024
KNOWLEDGE_VECTOR_FALLBACK_ALLOWED=false
