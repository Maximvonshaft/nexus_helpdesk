{
  "name": "helpdesk-suite-webapp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "e2e": "playwright test",
    "lint": "eslint . --max-warnings=0",
    "test": "node --test tests/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "architecture": "node scripts/assert-frontend-architecture.mjs && node scripts/assert-http-transport-authority.mjs",
    "verify": "npm run architecture && npm run lint && npm run typecheck && npm test && npm run build && node scripts/assert-route-splitting.mjs",
    "size-report": "node scripts/size-report.mjs"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "9.2.0",
    "@mui/material": "9.2.0",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-router": "1.170.18",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-is": "18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@playwright/test": "1.61.1",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "9.39.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.4.26",
    "globals": "16.5.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5"
  },
  "overrides": {
    "react-is": "18.3.1"
  }
}
