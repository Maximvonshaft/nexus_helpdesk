    "test": "tsx --test src/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "7.0.0-rc13",
    "pino": "9.14.0",
    "qrcode": "1.5.4"
  },
  "devDependencies": {
    "@types/node": "22.19.21",
    "@types/qrcode": "1.5.6",
    "tsx": "4.22.4",
    "typescript": "5.9.3"
  }
}
